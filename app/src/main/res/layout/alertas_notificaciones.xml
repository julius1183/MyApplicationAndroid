<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.AlertasNotificacionesActivity">


    <TextView
        android:id="@+id/textView4"
        android:layout_width="269dp"
        android:layout_height="28dp"
        android:text="Historial"
        tools:layout_editor_absoluteX="95dp"
        tools:layout_editor_absoluteY="682dp" />

    <ImageView
            android:id="@+id/iv_menu"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/logo_software"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="248dp" />

    <ImageView
        android:id="@+id/iv_alertas"
        android:layout_width="190dp"
        android:layout_height="216dp"
        android:layout_marginEnd="108dp"
        android:src="@drawable/alertas_notificaciones"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_informes"
        tools:layout_editor_absoluteY="266dp" />


    <ImageView
        android:id="@+id/iv_bconfiguracion"
        android:layout_width="62dp"
        android:layout_height="90dp"
        android:src="@drawable/boton_configuracion"
        tools:layout_editor_absoluteX="25dp"
        tools:layout_editor_absoluteY="526dp" />

    <ImageView
        android:id="@+id/iv_bconfiguracion"
        android:layout_width="62dp"
        android:layout_height="90dp"
        android:src="@drawable/historial"
        tools:layout_editor_absoluteX="23dp"
        tools:layout_editor_absoluteY="640dp" />






    <ImageView
            android:id="@+id/iv_regresar"
            android:layout_width="85dp"
            android:layout_height="112dp"
            android:src="@drawable/boton_regresar"
            android:layout_marginBottom="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="309dp"
        android:layout_height="27dp"
        android:text="Configuracion de alertas y notificaciones"
        tools:layout_editor_absoluteX="95dp"
        tools:layout_editor_absoluteY="564dp" />

    <Button
        android:id="@+id/button5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CERRAR SESION"
        tools:layout_editor_absoluteX="33dp"
        tools:layout_editor_absoluteY="160dp" />

</androidx.constraintlayout.widget.ConstraintLayout>