<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.Acercade">

    <ImageView
        android:id="@+id/iv_menu"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/logo_software"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="220dp" />

    <ImageView
        android:id="@+id/iv_proveedores"
        android:layout_width="90dp"
        android:layout_height="83dp"
        android:src="@drawable/gestion_proveedores"
        app:layout_constraintTop_toTopOf="@id/guideline_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/iv_entregas"
        app:layout_constraintHorizontal_chainStyle="spread_inside" />

    <ImageView
        android:id="@+id/iv_entregas"
        android:layout_width="90dp"
        android:layout_height="83dp"
        android:src="@drawable/entregas_pedidos"
        app:layout_constraintTop_toTopOf="@id/iv_proveedores"
        app:layout_constraintStart_toEndOf="@id/iv_proveedores"
        app:layout_constraintEnd_toStartOf="@id/iv_stock" />

    <ImageView
        android:id="@+id/iv_stock"
        android:layout_width="90dp"
        android:layout_height="83dp"
        android:src="@drawable/control_stock"
        app:layout_constraintTop_toTopOf="@id/iv_proveedores"
        app:layout_constraintStart_toEndOf="@id/iv_entregas"
        app:layout_constraintEnd_toStartOf="@id/iv_productos" />

    <ImageView
        android:id="@+id/iv_productos"
        android:layout_width="90dp"
        android:layout_height="83dp"
        android:src="@drawable/gestion_prodductos"
        app:layout_constraintTop_toTopOf="@id/iv_proveedores"
        app:layout_constraintStart_toEndOf="@id/iv_stock"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_usuarios"
        android:layout_width="90dp"
        android:layout_height="83dp"
        android:src="@drawable/usuarios_roles"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/iv_proveedores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_informes"
        app:layout_constraintHorizontal_chainStyle="spread_inside" />

    <ImageView
        android:id="@+id/iv_informes"
        android:layout_width="90dp"
        android:layout_height="83dp"
        android:src="@drawable/informes_analisis"
        app:layout_constraintTop_toTopOf="@id/iv_usuarios"
        app:layout_constraintStart_toEndOf="@id/iv_usuarios"
        app:layout_constraintEnd_toStartOf="@id/iv_alertas" />

    <ImageView
        android:id="@+id/iv_alertas"
        android:layout_width="90dp"
        android:layout_height="83dp"
        android:src="@drawable/alertas_notificaciones"
        app:layout_constraintTop_toTopOf="@id/iv_usuarios"
        app:layout_constraintStart_toEndOf="@id/iv_informes"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_regresar"
        android:layout_width="85dp"
        android:layout_height="112dp"
        android:src="@drawable/boton_regresar"
        android:layout_marginBottom="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>